# ── AI Provider (set via Settings page or env vars) ───────────────────────────
# Provider: anthropic | openai | local  (default: anthropic)
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=your_api_key_here
# AI_BASE_URL=   # only needed for local/custom OpenAI-compatible servers

# ── Legacy single-provider keys (still work as fallback) ──────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Database & uploads ────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./lamp_advisor.db
UPLOAD_DIR=./static/uploads
MAX_UPLOAD_MB=50
